# Docker Compose reads .env automatically when commands are run from ./src.
# Copy this file to .env for local overrides. Do not commit real .env files.

POSTGRES_DB=tic_tac_toe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_ENV=development
HTTP_ADDR=:8080

# Generate local RSA keys with:
#   sh scripts/generate-jwt-keys.sh
JWT_PRIVATE_KEY_PATH=./secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt/public.pem
JWT_PREVIOUS_PUBLIC_KEYS=
JWT_KEY_ID=tic-tac-toe-main
JWT_ISSUER=tic-tac-toe
JWT_AUDIENCE=tic-tac-toe-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Optional seed worker settings. Used by `make seed-db`.
SEED_USERS=10000
SEED_GAMES=100000
