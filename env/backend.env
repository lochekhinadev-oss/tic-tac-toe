APP_ENV=development
HTTP_PORT=8080

DATABASE_URL=postgres://postgres:postgres@db:5432/tic_tac_toe?sslmode=disable
REDIS_URL=redis://redis:6379/0

JWT_PRIVATE_KEY_PATH=./secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt/public.pem
JWT_PREVIOUS_PUBLIC_KEYS=
JWT_KEY_ID=tic-tac-toe-main
JWT_ISSUER=tic-tac-toe
JWT_AUDIENCE=tic-tac-toe-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

SEED_ENABLED=0
